{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "broadcast",
    "broadcast-alt"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "store:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart"
  ]
}
