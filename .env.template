# Non-secret local Whisper settings. Deepgram API keys are stored in the OS
# keychain from the app settings screen.
SABBATHCUE_FASTER_WHISPER_MODEL="tiny.en"
SABBATHCUE_FASTER_WHISPER_COMPUTE_TYPE="int8"
SABBATHCUE_FASTER_WHISPER_DEVICE="cpu"

# Supabase Auth (email/password). Copy Project URL and anon public key from
# Supabase Dashboard → Project Settings → API. Never commit the service-role key.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"
VITE_ACTIVATION_LEASE_PUBLIC_KEY="your-p256-spki-public-key-base64"

# Generate the activation lease key pair with:
# node scripts/generate-activation-lease-key.mjs
# Store ACTIVATION_LEASE_PRIVATE_KEY only in Supabase Edge Function secrets.

# Optional override for the browser password-reset page (defaults to GitHub Pages).
# VITE_PASSWORD_RESET_REDIRECT_URL="https://bongisto.github.io/SabbathCue/reset-password/"

# Paddle Billing (desktop app checkout). Create sandbox catalog + client token in Paddle.
# VITE_PADDLE_CLIENT_TOKEN="test_..."
# VITE_PADDLE_ENV="sandbox"
# VITE_PADDLE_PRICE_ID="pri_..."  # legacy alias for monthly
# VITE_PADDLE_PRICE_PRO_MONTH="pri_..."
# VITE_PADDLE_PRICE_PRO_YEAR="pri_..."

# EFT / direct deposit (South African bank transfer). Shown alongside Paddle on trial-expired.
# VITE_EFT_ACCOUNT_NAME="BongaNdlovu"
# VITE_EFT_BANK_NAME="Your bank"
# VITE_EFT_ACCOUNT_NUMBER="1234567890"
# VITE_EFT_BRANCH_CODE="123456"
# VITE_EFT_ACCOUNT_TYPE="Cheque"

# Paddle (marketing site checkout at web/pricing). Set in web/.env.local for local dev,
# Vercel project env for sabbath-cue-two.vercel.app, and in CI when building the static site.
# Vercel hybrid build: landing/ homepage + web/ checkout at /pricing/ and /pay/ (basePath "").
# Paddle default payment link (production): https://sabbath-cue-two.vercel.app/pay/
# Seed sandbox catalog:
#   PADDLE_API_KEY=pdl_sdbx_apikey_... node web/scripts/seed-paddle-sandbox-catalog.mjs
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_..."
# NEXT_PUBLIC_PADDLE_ENV="sandbox"
# NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTH="pri_..."
# NEXT_PUBLIC_PADDLE_PRICE_PRO_YEAR="pri_..."
# NEXT_PUBLIC_BASE_PATH="/SabbathCue"
# NEXT_PUBLIC_SITE_ORIGIN="http://localhost:3029"

# EFT / direct deposit on web/pricing (mirror VITE_EFT_* values).
# NEXT_PUBLIC_EFT_ACCOUNT_NAME="BongaNdlovu"
# NEXT_PUBLIC_EFT_BANK_NAME="Your bank"
# NEXT_PUBLIC_EFT_ACCOUNT_NUMBER="1234567890"
# NEXT_PUBLIC_EFT_BRANCH_CODE="123456"
# NEXT_PUBLIC_EFT_ACCOUNT_TYPE="Cheque"

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets).
# Never put these in NEXT_PUBLIC_* or VITE_* — server-side only.
# PADDLE_API_KEY="pdl_sdbx_apikey_..."          # API key (NOT the webhook secret)
# PADDLE_NOTIFICATION_WEBHOOK_SECRET="pdl_ntfset_..."  # signing secret for THIS destination
# PADDLE_ENV="sandbox"                          # required: sandbox | production (no silent default)
# Deploy: supabase functions deploy paddle-webhook paddle-portal paddle-cancel-subscription paddle-activate-subscription
# Webhook URL: https://<project-ref>.supabase.co/functions/v1/paddle-webhook
# Paddle default payment link (sandbox): http://localhost:3029/SabbathCue/pay/
# Create destination: Paddle → Developer tools → Notifications (or paddle-sandbox MCP)
# Subscribe: subscription.created/updated/canceled, customer.created/updated, transaction.completed
# Do NOT delete that destination, products, prices, or mirrored customers/subscriptions.

# Cursor Paddle MCP (optional — lets the agent create catalog, webhooks, simulate events).
# Copy .cursor/mcp.json.example into Cursor Settings → MCP Tools → mcp.json (or merge).
# Authorization must be: "Bearer pdl_sdbx_apikey_..." or "Bearer pdl_live_apikey_..."
# Use sandbox key only on sandbox-mcp.paddle.com; live key only on mcp.paddle.com.
# PADDLE_SANDBOX_API_KEY="pdl_sdbx_apikey_..."
# PADDLE_LIVE_API_KEY="pdl_live_apikey_..."

# --- Live migration (after sandbox testing passes) ---
# 1. bun run paddle:seed-live          # creates/reuses live catalog + client token (additive)
# 2. Copy .env.live.local → Vercel Production + root .env (live_ token, production pri_ IDs)
# 3. Supabase secrets: PADDLE_API_KEY (live), PADDLE_ENV=production, PADDLE_NOTIFICATION_WEBHOOK_SECRET
# 4. Paddle dashboard: default payment link https://sabbath-cue-two.vercel.app/pay/
# 5. bun run paddle:audit-live         # readiness check before verification
# Do NOT delete/recreate live notification destinations or prices with active subscriptions.
